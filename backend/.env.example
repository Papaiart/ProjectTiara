# A backend beallitasai. Masold le ezt a fajlt ".env" neven, es toltsd ki.

# A szerver portja
PORT=4000

# Titkos kulcs a bejelentkezeshez (JWT). Adj meg egy hosszu veletlen szoveget!
JWT_SECRET=valts-le-ezt-egy-hosszu-veletlen-titkos-kulcsra

# Honnan engedjuk a keres
# A GitHub Pages frontend cime (vesszovel tobb is megadhato)
CORS_ORIGIN=http://localhost:5173,https://FELHASZNALONEVED.github.io

# A backend nyilvanos cime (a feltoltott kepek URL-jehez hasznaljuk)
PUBLIC_URL=http://localhost:4000

# Az elso admin felhasznalo (a seed ezt hozza letre)
ADMIN_EMAIL=admin@tiara.hu
ADMIN_PASSWORD=valtsd-meg-ezt
ADMIN_USERNAME=Tiara

# E-mail kuldes (nyeremenyjatek / matrica rendeles urlapokhoz).
# Ha ures, akkor nem kuld emailt, csak naplozza a konzolra es eltarolja.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Ide erkeznek a beerkezo urlapok (a te emailed)
MAIL_TO=
# Errol a cimrol megy ki a level
MAIL_FROM=
